generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GENERAL
  ADMIN
}

enum MatchStatus {
  OPEN
  CLOSED
}

enum ClipStatus {
  OPEN
  CLOSED
}

model User {
  id        String @id @default(uuid())
  firstName String
  lastName  String
  email     String @unique
  password  String
  role      Role   @default(GENERAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchesAsReferee MatchReferee[]
  clipsAsReferee   ClipReferee[]
  clipsCreated     Clip[]         @relation("ClipCreator")
  comments         Comment[]
}

model Competition {
  id          String   @id @default(cuid())
  name        String
  seasonLabel String?  // ej: "Apertura 2026" (opcional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     Match[]  // lo vamos a crear en el próximo paso
}

model Match {
  id            String      @id @default(uuid())
  competitionId String
  teamA         String
  teamB         String
  category      String
  date          DateTime
  status        MatchStatus @default(OPEN)

  createdAt DateTime @default(now())

  competition Competition    @relation(fields: [competitionId], references: [id])
  referees    MatchReferee[]
  clips       Clip[]

  @@index([competitionId])
  @@index([date])
}

model MatchReferee {
  matchId String
  userId  String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@index([userId])
}

model Clip {
  id       String     @id @default(uuid())
  matchId  String
  title    String
  videoUrl String
  status   ClipStatus @default(OPEN)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdBy User  @relation("ClipCreator", fields: [createdById], references: [id])

  referees ClipReferee[]
  comments Comment[]

  finalDecisionCommentId String? @unique

  @@index([matchId])
  @@index([createdAt])
}

model ClipReferee {
  clipId String
  userId String

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([clipId, userId])
  @@index([userId])
}

model Comment {
  id      String @id @default(uuid())
  clipId  String
  userId  String
  content String

  isFinalDecision Boolean @default(false)

  createdAt DateTime @default(now())

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clipId])
  @@index([createdAt])
}
