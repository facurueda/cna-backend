generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GENERAL
  ADMIN
}

enum AppCredentialPlatform {
  ANDROID
  IOS
  WINDOWS
}

enum MatchStatus {
  OPEN
  CLOSED
}

enum ClipVisibility {
  PRIVATE
  PUBLIC
}

enum ExamStatus {
  PENDING
  FINISHED
}

enum ExamType {
  FINAL
  PRACTICE
}

enum FinalExamCatalogStatus {
  DRAFT
  PUBLISHED
}

model User {
  id                     String  @id @default(uuid())
  firstName              String
  lastName               String
  email                  String  @unique
  password               String
  refreshTokenHash       String?
  requiresPasswordChange Boolean @default(false)
  role                   Role    @default(GENERAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appCredentials           AppCredential[]
  matchesAsReferee         MatchReferee[]
  clipsCreated             Clip[]               @relation("ClipCreator")
  competitionsAsReferee    CompetitionReferee[]
  exams                    Exam[]
  stats                    UserStats?
  finalExamCatalogsCreated FinalExamCatalog[]   @relation("FinalExamCatalogCreator")
  userEvents               UserEvent[]
  buttonLayouts            ButtonLayout[]
  groups                   UserGroup[]
  passwordResetTokens      PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           UserGroup[]
  finalExamCatalogs FinalExamCatalogGroup[]

  @@index([name])
}

model UserGroup {
  groupId String
  userId  String

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model Competition {
  id          String   @id @default(cuid())
  name        String
  seasonLabel String? // ej: "Apertura 2026" (opcional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches  Match[]
  referees CompetitionReferee[]
}

model Match {
  id            String      @id @default(uuid())
  competitionId String
  teamA         String
  teamB         String
  category      String?
  date          DateTime?
  status        MatchStatus @default(OPEN)

  createdAt DateTime @default(now())

  competition Competition    @relation(fields: [competitionId], references: [id])
  referees    MatchReferee[]

  @@index([competitionId])
  @@index([date])
}

model MatchReferee {
  matchId String
  userId  String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@index([userId])
}

model CompetitionReferee {
  competitionId String
  userId        String

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([competitionId, userId])
  @@index([userId])
}

model ClipCollection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clips Clip[]
}

model Clip {
  id           String         @id @default(uuid())
  collectionId String
  categoryId   String
  title        String
  description  String
  videoUrl     String
  thumbnailUrl String?
  duration     Int?
  visibility   ClipVisibility @default(PRIVATE)
  publishedAt  DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collection ClipCollection @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  category   ClipCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy  User           @relation("ClipCreator", fields: [createdById], references: [id])

  @@index([collectionId])
  @@index([categoryId])
  @@index([visibility, createdAt])
  @@index([createdAt])
  @@index([publishedAt])
}

model ClipCategory {
  id   String @id @default(cuid())
  name String @unique

  clips Clip[]
}

model Exam {
  id                   String     @id @default(uuid()) @db.Uuid
  userId               String
  finalExamCatalogId   String?    @db.Uuid
  attemptNumber        Int?
  questionCount        Int
  isTimed              Boolean    @default(false)
  totalTimeSeconds     Int?
  status               ExamStatus @default(PENDING)
  examType             ExamType
  passThresholdPercent Int        @default(70)
  correctCount         Int?
  wrongCount           Int?
  scorePercent         Float?
  isPassed             Boolean?
  finishedAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  finalExamCatalog FinalExamCatalog? @relation(fields: [finalExamCatalogId], references: [id], onDelete: SetNull)
  questions        ExamQuestion[]

  @@unique([userId, finalExamCatalogId, attemptNumber])
  @@index([userId])
  @@index([finalExamCatalogId])
  @@index([status])
  @@index([createdAt])
}

model ExamQuestion {
  id           String  @id @default(uuid()) @db.Uuid
  examId       String  @db.Uuid
  position     Int
  questionCode String
  questionText String
  categoryName String?

  exam        Exam                     @relation(fields: [examId], references: [id], onDelete: Cascade)
  options     ExamQuestionOption[]
  correctKeys ExamQuestionCorrectKey[]
  responses   ExamQuestionResponse[]

  @@unique([examId, position])
  @@index([examId])
}

model ExamQuestionOption {
  id             String @id @default(uuid()) @db.Uuid
  examQuestionId String @db.Uuid
  position       Int
  key            String
  text           String

  examQuestion ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@unique([examQuestionId, key])
  @@index([examQuestionId])
  @@index([examQuestionId, position])
}

model ExamQuestionCorrectKey {
  id             String @id @default(uuid()) @db.Uuid
  examQuestionId String @db.Uuid
  key            String

  examQuestion ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@unique([examQuestionId, key])
  @@index([examQuestionId])
}

model ExamQuestionResponse {
  id             String @id @default(uuid()) @db.Uuid
  examQuestionId String @db.Uuid
  key            String

  examQuestion ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@unique([examQuestionId, key])
  @@index([examQuestionId])
}

model UserStats {
  userId                String   @id
  practiceTestsCount    Int      @default(0)
  practiceAverage       Float    @default(0)
  finalTestsPassedCount Int      @default(0)
  finalTestsTotalCount  Int      @default(0)
  finalAverage          Float    @default(0)
  clipsCount            Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practiceAverage])
  @@index([finalAverage])
}

model FinalExamCatalog {
  id                   String                 @id @default(uuid()) @db.Uuid
  title                String                 @default("Examen")
  questionCount        Int
  isTimed              Boolean                @default(false)
  totalTimeSeconds     Int?
  availableUntilDate   String?
  maxRetries           Int                    @default(0)
  shuffleOptions       Boolean                @default(true)
  passThresholdPercent Int                    @default(70)
  status               FinalExamCatalogStatus @default(DRAFT)
  publishedAt          DateTime?
  createdById          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  createdBy      User?                       @relation("FinalExamCatalogCreator", fields: [createdById], references: [id], onDelete: SetNull)
  categories     FinalExamCatalogCategory[]
  groups         FinalExamCatalogGroup[]
  fixedQuestions FinalExamCatalogQuestion[]
  exams          Exam[]

  @@index([status])
  @@index([createdAt])
}

model FinalExamCatalogQuestion {
  finalExamCatalogId String @db.Uuid
  questionId         String @db.Uuid
  position           Int

  finalExamCatalog FinalExamCatalog @relation(fields: [finalExamCatalogId], references: [id], onDelete: Cascade)
  question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([finalExamCatalogId, questionId])
  @@index([finalExamCatalogId])
}

model FinalExamCatalogCategory {
  finalExamCatalogId String @db.Uuid
  categoryId         String @db.Uuid

  finalExamCatalog FinalExamCatalog @relation(fields: [finalExamCatalogId], references: [id], onDelete: Cascade)
  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([finalExamCatalogId, categoryId])
  @@index([categoryId])
}

model FinalExamCatalogGroup {
  finalExamCatalogId String @db.Uuid
  groupId            String

  finalExamCatalog FinalExamCatalog @relation(fields: [finalExamCatalogId], references: [id], onDelete: Cascade)
  group            Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([finalExamCatalogId, groupId])
  @@index([groupId])
}

model Question {
  id         String   @id @default(uuid()) @db.Uuid
  code       String
  text       String
  categoryId String?  @db.Uuid
  order      Int      @map("Order")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category          Category?                  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  answers           Answer[]
  correctAnswerKeys QuestionCorrectAnswerKey[]
  finalExamCatalogs FinalExamCatalogQuestion[]
}

model Answer {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @db.Uuid
  key        String
  text       String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions         Question[]
  finalExamCatalogs FinalExamCatalogCategory[]
}

model QuestionCorrectAnswerKey {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @db.Uuid
  key        String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, key])
  @@index([questionId])
}

model AppCredential {
  id         String                @id @default(cuid())
  userId     String
  platform   AppCredentialPlatform
  name       String
  secretHash String
  scopes     String[]
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  device AppCredentialDevice?

  @@index([userId])
  @@index([platform])
  @@index([revokedAt])
}

model AppCredentialDevice {
  id                  String   @id @default(cuid())
  appCredentialId     String   @unique
  deviceId            String
  brand               String?
  model               String?
  os                  String?
  osVersion           String?
  appVersion          String?
  buildVersion        String?
  timezone            String?
  locale              String?
  isPhysicalDevice    Boolean?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  appCredential AppCredential @relation(fields: [appCredentialId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

model UserEvent {
  id        String   @id @default(uuid())
  userId    String
  eventName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items UserEventItem[]

  @@index([userId])
  @@index([createdAt])
  @@map("eventos")
}

model ButtonLayout {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tiles ButtonLayoutTile[]

  @@index([userId])
  @@index([createdAt])
}

model ButtonLayoutTile {
  id             String @id @default(uuid())
  buttonLayoutId String
  position       Int
  label          String
  colSpan        Int
  rowSpan        Int
  tone           String

  buttonLayout ButtonLayout @relation(fields: [buttonLayoutId], references: [id], onDelete: Cascade)

  @@unique([buttonLayoutId, position])
  @@index([buttonLayoutId])
}

model StudyMaterial {
  id           String   @id @default(uuid()) @db.Uuid
  url          String
  documentName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserEventItem {
  id          String   @id @default(uuid())
  eventId     String
  position    Int
  category    String
  createdAt   DateTime
  endTime     String
  endTimeMs   Int
  eventTimeMs Int
  incrementId Int
  startTime   String
  startTimeMs Int
  tileId      String
  title       String

  event UserEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, position])
  @@index([eventId])
  @@index([tileId])
  @@map("evento_items")
}
