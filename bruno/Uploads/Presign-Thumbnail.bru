meta {
  name: Presign Thumbnail
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/uploads/presign
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  "competitionId": "{{competitionId}}",
  "matchId": "{{matchId}}",
  "fileName": "thumb.webp",
  "contentType": "image/webp",
  "assetType": "image",
  "size": 345678
}
