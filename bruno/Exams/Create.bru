meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/exams
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  "questionCount": 10,
  "categoryIds": ["{{questionCategoryId1}}", "{{questionCategoryId2}}"],
  "isTimed": true,
  "totalTimeSeconds": 900,
  "examType": "PRACTICE"
}
